// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───

enum PaymentStatus {
  CREATED
  PENDING
  PROCESSING
  SUCCESS
  FAILED
  RETRY_SCHEDULED
  PERMANENTLY_FAILED
  CANCELLED
}

enum WebhookEventStatus {
  PROCESSED
  REJECTED
  DUPLICATE
}

enum IdempotencyKeyStatus {
  PROCESSING
  COMPLETED
}

// ─── Models ───

/// Core payment record with optimistic locking via `version` field.
model Payment {
  id               String        @id @default(uuid()) @db.Uuid
  amount           Decimal       @db.Decimal(12, 2)
  currency         String        @db.VarChar(3)
  status           PaymentStatus @default(CREATED)
  merchantId       String        @map("merchant_id") @db.VarChar(64)
  customerEmail    String        @map("customer_email") @db.VarChar(255)
  description      String?       @db.Text
  gatewayReference String?       @map("gateway_reference") @db.VarChar(255)
  idempotencyKey   String?       @unique @map("idempotency_key") @db.VarChar(255)
  retryCount       Int           @default(0) @map("retry_count")
  maxRetries       Int           @default(3) @map("max_retries")
  errorCode        String?       @map("error_code") @db.VarChar(64)
  errorMessage     String?       @map("error_message") @db.Text
  version          Int           @default(1)
  metadata         Json?         @db.JsonB
  processedAt      DateTime?     @map("processed_at")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  // Relations
  paymentEvents PaymentEvent[]
  webhookEvents WebhookEvent[]

  // Indexes
  @@index([status])
  @@index([merchantId])
  @@index([createdAt])
  @@index([idempotencyKey])
  @@map("payments")
}

/// Audit trail for every payment state transition.
model PaymentEvent {
  id         String   @id @default(uuid()) @db.Uuid
  paymentId  String   @map("payment_id") @db.Uuid
  fromStatus String?  @map("from_status") @db.VarChar(32)
  toStatus   String   @map("to_status") @db.VarChar(32)
  eventType  String   @map("event_type") @db.VarChar(64)
  eventData  Json?    @map("event_data") @db.JsonB
  createdAt  DateTime @default(now()) @map("created_at")

  // Relations
  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  // Indexes
  @@index([paymentId])
  @@index([createdAt])
  @@map("payment_events")
}

/// Log of received webhook callbacks with deduplication.
model WebhookEvent {
  id        String             @id @default(uuid()) @db.Uuid
  paymentId String             @map("payment_id") @db.Uuid
  eventId   String             @unique @map("event_id") @db.VarChar(255)
  eventType String             @map("event_type") @db.VarChar(64)
  payload   Json               @db.JsonB
  signature String             @db.VarChar(512)
  status    WebhookEventStatus
  createdAt DateTime           @default(now()) @map("created_at")

  // Relations
  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  // Indexes
  @@index([paymentId])
  @@index([eventId])
  @@map("webhook_events")
}

/// Persisted idempotency records for durability beyond Redis TTL.
model IdempotencyKey {
  id              String               @id @default(uuid()) @db.Uuid
  key             String               @unique @db.VarChar(255)
  requestPath     String               @map("request_path") @db.VarChar(255)
  requestBodyHash String               @map("request_body_hash") @db.VarChar(64)
  responseCode    Int?                 @map("response_code")
  responseBody    Json?                @map("response_body") @db.JsonB
  status          IdempotencyKeyStatus @default(PROCESSING)
  expiresAt       DateTime             @map("expires_at")
  createdAt       DateTime             @default(now()) @map("created_at")

  // Indexes
  @@index([key])
  @@index([expiresAt])
  @@map("idempotency_keys")
}
